NODE_ENV=development
LOG_LEVEL=info

DATABASE_URL=postgres://openprovider:dev@localhost:5432/openprovider_mcp
DATABASE_MIGRATION_URL=postgres://openprovider:dev@localhost:5432/openprovider_mcp

AWS_REGION=eu-central-1
AWS_KMS_KEY_ARN=alias/openprovider-mcp-dev
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
DEV_BEARER_TOKEN=dev-bearer-only-for-phase1

# For an MCP server, AuthKit is the OAuth authorization server: the issuer and
# JWKS are your AuthKit domain (confirm against
# https://<authkit-domain>/.well-known/oauth-authorization-server), NOT api.workos.com.
WORKOS_CLIENT_ID=client_replace_me
WORKOS_API_KEY=sk_test_replace_me
WORKOS_AUTHKIT_DOMAIN=https://your-org.authkit.app
WORKOS_ISSUER=https://your-org.authkit.app
WORKOS_JWKS_URI=https://your-org.authkit.app/oauth2/jwks
