{
  "name": "openprovider-mcp",
  "version": "0.2.0-phase1.0",
  "private": true,
  "description": "Enterprise multi-tenant MCP server for Openprovider",
  "type": "module",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --enable-source-maps dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.600.0",
    "@fastify/rate-limit": "^10.3.0",
    "@modelcontextprotocol/sdk": "^1.17.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.52.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.55.0",
    "@opentelemetry/sdk-node": "^0.55.0",
    "@workos-inc/node": "^9.3.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.36.0",
    "fastify": "^4.28.1",
    "jose": "^6.2.3",
    "opossum": "^5.0.1",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "prettier --write",
      "eslint --max-warnings=0"
    ]
  },
  "devDependencies": {
    "@testcontainers/localstack": "^12.0.0",
    "@testcontainers/postgresql": "^12.0.0",
    "@types/node": "^20.14.0",
    "@types/opossum": "^8.1.9",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^1.6.0",
    "drizzle-kit": "^0.28.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "nock": "^14.0.15",
    "prettier": "^3.3.3",
    "testcontainers": "^10.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^1.6.0"
  }
}
