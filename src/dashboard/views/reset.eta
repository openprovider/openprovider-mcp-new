<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Reset Password — Openprovider MCP</title>
  <style>
    body { font-family: system-ui, sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; background: #f5f5f5; }
    .card { background: #fff; padding: 2rem 2.5rem; border-radius: 8px; box-shadow: 0 2px 12px rgba(0,0,0,0.1); min-width: 320px; }
    h1 { margin: 0 0 1.25rem; font-size: 1.5rem; text-align: center; }
    .error { color: #c0392b; margin-bottom: 1rem; padding: 0.5rem; background: #fdecea; border-radius: 4px; font-size: 0.9rem; }
    .notice { color: #155724; margin-bottom: 1rem; padding: 0.5rem; background: #d4edda; border-radius: 4px; font-size: 0.9rem; }
    label { display: block; margin-bottom: 0.25rem; font-size: 0.875rem; font-weight: 500; }
    input[type="password"] { width: 100%; box-sizing: border-box; padding: 0.5rem 0.75rem; border: 1px solid #ccc; border-radius: 4px; font-size: 1rem; margin-bottom: 1rem; }
    button[type="submit"] { width: 100%; background: #1a1a2e; color: #fff; padding: 0.65rem 1rem; border: none; border-radius: 4px; font-size: 1rem; cursor: pointer; }
    button[type="submit"]:hover { background: #2a2a4e; }
  </style>
</head>
<body>
<div class="card">
  <h1>Reset password</h1>
  <% if (it.notice) { %>
  <p class="notice"><%= it.notice %></p>
  <% } %>
  <% if (it.error) { %>
  <p class="error"><%= it.error %></p>
  <% } %>
  <form method="POST" action="/dashboard/reset">
    <input type="hidden" name="token" value="<%= it.token %>">
    <label for="password">New password (min 12 characters)</label>
    <input type="password" id="password" name="password" autocomplete="new-password" required minlength="12">
    <button type="submit">Set new password</button>
  </form>
</div>
</body>
</html>
