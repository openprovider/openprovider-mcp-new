<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Openprovider MCP</title>
  <script src="/dashboard/static/htmx.min.js"></script>
  <style>
    body { font-family: system-ui, sans-serif; margin: 0; padding: 0; }
    header { background: #1a1a2e; color: #fff; padding: 0.75rem 1.5rem; display: flex; align-items: center; gap: 1rem; }
    header a { color: #e0e0e0; text-decoration: none; }
    header a:hover { color: #fff; }
    header form { margin: 0; margin-left: auto; }
    header button { background: transparent; border: 1px solid #e0e0e0; color: #e0e0e0; padding: 0.25rem 0.75rem; cursor: pointer; border-radius: 4px; }
    header button:hover { background: rgba(255,255,255,0.1); }
    main { padding: 1.5rem; max-width: 1100px; margin: 0 auto; }
  </style>
</head>
<body>
<header>
  <strong>Openprovider MCP</strong>
  <a href="/dashboard">Overview</a>
  <a href="/dashboard/openprovider">Openprovider</a>
  <a href="/dashboard/policy">Policy</a>
  <a href="/dashboard/keys">API Keys</a>
  <a href="/dashboard/audit">Audit</a>
  <a href="/dashboard/confirmations">Confirmations</a>
  <form method="post" action="/dashboard/logout">
    <button type="submit">Logout</button>
  </form>
</header>
<main><%~ it.body %></main>
</body>
</html>
