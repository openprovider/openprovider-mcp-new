<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Sign in — Openprovider MCP</title>
  <style>
    body { font-family: system-ui, sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; background: #f5f5f5; }
    .card { background: #fff; padding: 2rem 2.5rem; border-radius: 8px; box-shadow: 0 2px 12px rgba(0,0,0,0.1); text-align: center; min-width: 320px; }
    h1 { margin: 0 0 1rem; font-size: 1.5rem; }
    .error { color: #c0392b; margin-bottom: 1rem; padding: 0.5rem; background: #fdecea; border-radius: 4px; }
    a.btn { display: inline-block; background: #1a1a2e; color: #fff; padding: 0.6rem 1.5rem; border-radius: 4px; text-decoration: none; margin-top: 1rem; }
    a.btn:hover { background: #2a2a4e; }
  </style>
</head>
<body>
<div class="card">
  <h1>Sign in</h1>
  <% if (it.error) { %>
  <p class="error"><%= it.error %></p>
  <% } %>
  <p>Sign in with your WorkOS account to access the Openprovider MCP dashboard.</p>
  <a class="btn" href="/dashboard/login">Continue with WorkOS</a>
</div>
</body>
</html>
